{
  "name": "vizor-vr/laravel-vizor",
  "description": "Laravel Livewire components for the Vizor VR video player",
  "keywords": ["laravel", "livewire", "vr", "360", "video", "player", "webxr", "alpine"],
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0|^12.0",
    "illuminate/http": "^11.0|^12.0",
    "illuminate/view": "^11.0|^12.0",
    "livewire/livewire": "^3.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0",
    "larastan/larastan": "^2.0|^3.0",
    "laravel/pint": "^1.0"
  },
  "suggest": {
    "filament/filament": "Required for Filament admin panel integration (^3.0)",
    "laravel/echo": "Required for real-time event broadcasting",
    "pusher/pusher-php-server": "Required for Pusher broadcasting driver"
  },
  "autoload": {
    "psr-4": {
      "Vizor\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Vizor\\Laravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Vizor\\Laravel\\VizorServiceProvider"
      ],
      "aliases": {
        "Vizor": "Vizor\\Laravel\\Facades\\Vizor"
      }
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
